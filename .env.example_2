APP_NAME="IL-DASH"
APP_ENV=local
APP_KEY=base64:6+0GP5739l0x5cNHdgCCyCztvCDvIalHlWbWZNx9lgo=
APP_DEBUG=true
APP_TIMEZONE=Africa/Lagos
APP_URL=https://api.eventsintel.com
